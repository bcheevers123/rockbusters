# Rockbusters — environment variable reference
# Copy this file to .env and fill in the values for local development.
# Never commit .env to version control.

# Path to the SQLite database file.
SQLITE_PATH=rockbusters.db

# Path to the YAML question bank (relative to project root).
ROCKBUSTERS_BANK_PATH=data/rockbusters.yaml

# IANA timezone name used to determine the current "game day".
APP_TIMEZONE=Europe/London

# Comma-separated origins allowed by the CORS middleware.
# Use * during local development; restrict to your Pages domain in production.
ALLOWED_ORIGINS=*

# Optional bearer token for protecting write endpoints in production.
# Leave blank to disable token-based auth.
API_SECRET=
